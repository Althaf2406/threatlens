PROJECT_NAME="ThreatLens API"
API_V1_STR="/api/v1"
SECRET_KEY="supersecretkey-please-change-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Using SQLite for local development
DATABASE_URL="sqlite:///./threatlens.db"

# Email Configuration
EMAIL_PROVIDER="smtp" # Use 'console' for local dev without smtp
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
EMAIL_FROM="noreply@threatlens.local"
FRONTEND_ORIGIN="http://localhost:3000"
